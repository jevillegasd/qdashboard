# QDashboard environment configuration
# Copy this file to .env and adjust for your deployment.
# .env is gitignored — never commit it.

# Root directory for all QDashboard state (logs, tmp, data).
# Defaults to ~/.qdashboard when unset.
QD_ROOT=~/.qdashboard

# Directory the file browser serves. Defaults to $QD_ROOT/data.
QD_DATA_DIR=~/.qdashboard/data

# Server binding
QD_HOST=127.0.0.1
QD_PORT=5005

# Optional authentication key (base64 username:password or arbitrary token)
# QD_KEY=

# Environment label shown in the UI
QD_ENVIRONMENT=default

# Path to the SLURM output log file
QD_LOG_PATH=~/.qdashboard/logs/slurm_output.txt

# Enable Uvicorn reload / verbose logging
QD_DEBUG=true

# Override the user home path (used for SLURM defaults)
# QD_HOME_PATH=/home/youruser

# Path to the qibolab platforms repository
# QIBOLAB_PLATFORMS=/path/to/qibolab_platforms
